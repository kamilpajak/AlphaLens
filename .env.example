# Copy to .env and fill in the values. Names + placeholders only — never
# commit real secrets. This is the full operator catalogue for the repo root
# .env (the deploy/docker/.env.example is the narrower container pass-through
# subset). The local .venv reads this directly; the VPS keeps its own copy at
# /etc/alphalens/env.

# --- LLM providers ---------------------------------------------------------

# OpenRouter — DeepSeek v4 Flash + Pro for the thematic pipeline and the
# research-side llm_scorers (migrated off Gemini per PR-G). Distinct from the
# zen-codereview OpenRouter key, for cost-attribution isolation.
OPENROUTER_API_KEY=

# --- Data vendors ----------------------------------------------------------

# Alpha Vantage — EARNINGS endpoint (paradigm-14 PEAD backfill + next-earnings
# date in briefs). Free tier 25 req/day, quota is per-key.
ALPHA_VANTAGE_API_KEY=

# Polygon — news firehose + minute bars (press gate, broker-free ladder
# replay). ~$30/mo Starter; quota is per-key.
POLYGON_API_KEY=

# FRED (St. Louis Fed) — macro / VIX series. Stamps market_regime_at_entry in
# the daily thematic build via the canonical FREDClient.
FRED_API_KEY=

# Perplexity — literature_review weekly + monthly scans only (not the thematic
# pipeline).
PERPLEXITY_API_KEY=

# --- Notifications ---------------------------------------------------------

# Telegram bot — brief notifications (backlog item; not yet wired live).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- SEC EDGAR -------------------------------------------------------------

# SEC EDGAR contact string (email or URL). Not stored in the live root .env
# today — the canonical SecEdgarClient falls back to a built-in default UA —
# but SEC returns 403 without a contact under load, so set it in production.
SEC_EDGAR_USER_AGENT=

# --- Broker (execution) ----------------------------------------------------
# Saxo Bank OpenAPI, SIM environment ONLY (ADR 0014 — the LIVE gateway is
# structurally unreachable in code; lifting that rail requires its own ADR).
# P4 adds SAXO_APP_KEY / SAXO_APP_SECRET / SAXO_TOKEN_STORE_PATH for OAuth.
# NOTE: the old SAXO_* keys were purged from /etc/alphalens/env with ADR 0012;
# re-adding on the VPS is an operator runbook step when a VPS consumer appears.

# 24-hour Developer-Portal SIM token — EXPIRES DAILY; regenerate manually at
# developer.saxo until P4 OAuth lands. Read by StaticTokenProvider.
SAXO_SIM_TOKEN=

# Optional: pick one AccountKey when the Saxo profile has several accounts.
# With a single account the broker auto-picks; with several and this unset,
# `alphalens broker account` fails loudly rather than guessing.
# SAXO_ACCOUNT_KEY=

# SAXO_LIVE_TEST=1 (flag, not a secret) opts into the live SIM probe
# `tests/live/test_saxo_live.py` — needs a fresh SAXO_SIM_TOKEN + network.

# --- RESEARCH-ONLY / optional ----------------------------------------------
# Keys consumed only by ad-hoc research scripts or expired subscriptions. Safe
# to leave blank for the live thematic pipeline.

# SimFin — alternate fundamentals source; research-only, no live consumer.
SIMFIN_API_KEY=

# Quiver — alternate alt-data source; research-only, no live consumer.
QUIVER_API_KEY=

# iVolatility — options-implied retrospectives; subscription expired 2026-05-10,
# kept for cache replay only.
IVOLATILITY_API_KEY=

# runpod.io — CPU/GPU pod bootstrap for audits; used by the runpod CLI, not by
# any in-repo Python module.
RUNPOD_API_KEY=

# --- DEAD (do NOT fill in — kept only to document removal) ------------------
# These keys linger in some live .env copies but have ZERO source consumers.
# Remove them from /etc/alphalens/env at the next VPS maintenance window.

# GOOGLE_API_KEY — DEAD. The Gemini client was removed (PR #416); every LLM
# call now routes through OPENROUTER_API_KEY.
# GOOGLE_API_KEY=

# ALPACA_* — DEAD. The paper-trade + broker chain was decommissioned
# (ADR 0012). No code reads these any more.
# ALPACA_API_BASE_URL=
# ALPACA_API_KEY=
# ALPACA_API_SECRET=
# ALPACA_TEST_API_KEY=
# ALPACA_TEST_API_SECRET=
