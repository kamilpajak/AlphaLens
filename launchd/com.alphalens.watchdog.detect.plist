<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.alphalens.watchdog.detect</string>

    <key>ProgramArguments</key>
    <array>
        <string>/Users/jacoren/Developer/Personal/AlphaLens/TradingAgents/.venv/bin/tradingagents</string>
        <string>watchdog</string>
        <string>run-once</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/jacoren/Developer/Personal/AlphaLens/TradingAgents</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/usr/bin:/bin:/usr/sbin:/sbin:/usr/local/bin:/opt/homebrew/bin</string>
    </dict>

    <key>StartInterval</key>
    <integer>900</integer>

    <key>StandardOutPath</key>
