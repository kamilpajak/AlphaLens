#!/bin/bash
# Layer 2d insider cluster-buy scan — daily GATE 1 forward paper data collection.
# Writes markdown report to ~/.alphalens/insider/daily_{date}.md so GATE 1
# firing-rate check (Perplexity R8 Q5) can aggregate 5 trading days before
# the Phase 2.5 invest/pivot decision.
DATE="$(date +%Y-%m-%d)"
exec /Users/jacoren/Developer/Personal/AlphaLens/.venv/bin/alphalens insider screen \
    --dry-run \
    --top-n 20 \
    --report "$HOME/.alphalens/insider/daily_${DATE}.md" \
    "$@"
