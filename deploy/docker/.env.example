# Copy to .env and fill in. The pipeline service reads this via env_file.

# Gemini Flash (theme extraction) and Pro (beneficiary mapping).
GOOGLE_API_KEY=

# Polygon (news firehose, ~$30/mo Starter — required for press gate).
POLYGON_API_KEY=

# Alpha Vantage (paradigm-14 EARNINGS endpoint — required for next_earnings_date in briefs).
ALPHA_VANTAGE_API_KEY=

# Perplexity (optional — only used by literature_review, not the thematic pipeline).
PERPLEXITY_API_KEY=

# Telegram bot (optional — for brief notifications, currently a backlog item).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
