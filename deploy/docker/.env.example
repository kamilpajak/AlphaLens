# Copy to .env and fill in. The pipeline service reads this via env_file.

# SEC EDGAR contact (mandatory — SEC returns 403 without it). Email or URL
# in the value; one var for the entire repo. Single source of truth for the
# canonical SecEdgarClient singleton used by watchdog + thematic verification
# + EDGAR fundamentals.
SEC_EDGAR_USER_AGENT=

# OpenRouter — DeepSeek v4 Flash (theme extraction) + Pro (beneficiary mapping)
# for the thematic pipeline (migrated off Gemini per PR-G). Distinct from the
# zen-codereview OpenRouter key, for cost-attribution isolation.
OPENROUTER_API_KEY=

# Google AI (Gemini) — research-side only now: the ad-hoc analyze_rejections.py
# script. The thematic pipeline no longer uses it (see OPENROUTER_API_KEY above).
GOOGLE_API_KEY=

# Polygon (news firehose, ~$30/mo Starter — required for press gate).
POLYGON_API_KEY=

# Alpha Vantage (paradigm-14 EARNINGS endpoint — required for next_earnings_date in briefs).
ALPHA_VANTAGE_API_KEY=

# FRED (Federal Reserve macro data) — VIX refresh in the daily thematic build
# stamps market_regime_at_entry via the canonical FREDClient (PR #354).
FRED_API_KEY=

# Perplexity (optional — only used by literature_review, not the thematic pipeline).
PERPLEXITY_API_KEY=

# Telegram bot (optional — for brief notifications, currently a backlog item).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
