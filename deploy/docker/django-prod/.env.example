# Production .env — copy to .env, fill in real values, never commit.

# --- Django ---
SECRET_KEY=replace-me-with-a-50-byte-random-string
ALLOWED_HOSTS=api.example.com,localhost

# CORS — same-domain-cookies auth (Path A per apps/web/README.md).
# CORS_ALLOWED_ORIGINS = literal production SPA URL.
# CORS_ALLOWED_ORIGIN_REGEXES = preview-branch pages.dev pattern.
# CORS_ALLOW_CREDENTIALS = required so browsers send CF_Authorization
# cookie cross-origin.
CORS_ALLOWED_ORIGINS=https://app.example.com
CORS_ALLOWED_ORIGIN_REGEXES=^https://[\w-]+\.alphalens\.pages\.dev$
CORS_ALLOW_CREDENTIALS=True

# --- Database ---
POSTGRES_PASSWORD=replace-me-with-a-strong-password

# --- Cloudflare Access ---
# From your Cloudflare zero-trust dashboard → Access → Applications → AUD tag
CF_ACCESS_TEAM=your-team
CF_ACCESS_AUD=
CF_ACCESS_REQUIRED=true

# --- Paths ---
# Host path that holds the daily brief parquets. Mounted read-only into
# the django + rebuild-cache containers.
BRIEFS_DIR=/var/lib/alphalens/thematic_briefs

# --- Image tag (canonical compose only) ---
# GHCR tag for the django image. `latest` follows main but is MUTABLE — for
# prod, prefer pinning the IMMUTABLE `sha-<short>` of the deployed commit so a
# later rebuild or rollback cannot silently change what runs, and so the
# long-running `django` + the one-shot `rebuild-cache` always agree on one
# image (the migrate-on-start drift class). CI publishes both `latest` and
# `sha-<short>` per .github/workflows/django-image.yml. After deploy, verify
# the running image matches the intended commit with
# `deploy/scripts/postdeploy_check.sh`. Edit this value in .env (do NOT pass
# inline via `ALPHALENS_DJANGO_TAG=... docker compose up -d`) — Compose reads
# .env on every command, so an inline value is lost the next time someone runs
# `up -d` without it, silently rolling forward to `:latest`.
ALPHALENS_DJANGO_TAG=latest

# --- Compose file pinning (VPS only — uncomment) ---
# Forces Compose to ignore docker-compose.override.yaml. Without this,
# a stray `docker compose up -d` on the VPS would auto-load the override
# and try to build the image locally / spin up nginx, neither of which
# belongs on the VPS. Local dev leaves this unset so the override loads.
# COMPOSE_FILE=docker-compose.yaml

# --- Local dev only (docker-compose.override.yaml) ---
# Path to the SvelteKit build, bind-mounted into the local nginx. Run
# ``pnpm --filter web build`` on the host first.
SPA_DIST=../../../apps/web/build

# Public port of the local nginx. On the VPS, cloudflared maps
# api.<domain> to 127.0.0.1:8000 directly — no nginx, this var unused.
NGINX_HTTP_PORT=8080
