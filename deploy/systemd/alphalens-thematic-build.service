[Unit]
# AlphaLens thematic pipeline — runs the daily news → brief refresh
# end-to-end via the pipeline image (built standalone from
# deploy/docker/Dockerfile.pipeline). The Django stack picks up the
# new parquet output via a one-shot `rebuild-cache` invocation in
# ExecStartPost.
#
# Install as a *user* unit alongside the companion timer:
#
#   mkdir -p ~/.config/systemd/user
#   cp deploy/systemd/alphalens-thematic-build.service ~/.config/systemd/user/
#   cp deploy/systemd/alphalens-thematic-build.timer   ~/.config/systemd/user/
#   systemctl --user daemon-reload
#   systemctl --user enable --now alphalens-thematic-build.timer
#
# Inspect:           journalctl --user -u alphalens-thematic-build.service -f
# Trigger manually:  systemctl --user start alphalens-thematic-build.service
#
# Persistence (survives logout) — once, as the user:
#   sudo loginctl enable-linger "$USER"
Description=AlphaLens thematic build (daily)
After=network-online.target docker.service
Wants=network-online.target

[Service]
Type=oneshot
WorkingDirectory=%h/AlphaLens

# Pipeline secrets live in /etc/alphalens/env (root:root chmod 600). systemd
# loads them into the unit's process env, and the explicit `-e KEY` flags
# below cherry-pick which ones cross into the container. No leading `-`:
# if the file is missing the unit MUST fail loud rather than limp on
# without secrets (Polygon skipped, Gemini extract fails partway, partial
# parquet poisons cache). See deploy/systemd/README.md "Environment file
# setup" for the bootstrap recipe.
EnvironmentFile=/etc/alphalens/env

# Inherit operator UID/GID into the pipeline container so bind-mount writes
# land as the user, not root. The `-e KEY` form (no `=value`) tells docker
# to copy the value from the calling env — that's where systemd's
# EnvironmentFile vars live. Adding a new pipeline secret means: update
# /etc/alphalens/env on the host AND add a `-e NEW_KEY` line below.
#
# ALPHALENS_TEXTFILE_DIR is the one exception that carries an explicit
# `=value`: it is a non-secret infra path (the node_exporter textfile
# scrape dir), and the container's emit_domain_metrics must write the
# thematic stage gauges (#373/#374) + the VIX freshness gauge (#376) THERE,
# not into the `~/.alphalens` bind mount (which node_exporter does NOT
# scrape — live --collector.textfile.directory=/var/lib/node_exporter/
# textfile). The identity `-v` mount makes that container path the host's
# real scrape dir; the explicit value (vs bare `-e KEY`) keeps the routing
# correct even if /etc/alphalens/env never defines the var.
ExecStart=/usr/bin/env UID=%U GID=%G /usr/bin/docker run --rm \
    --user %U:%G \
    -e HOME=/app/home \
    -e OPENROUTER_API_KEY \
    -e GOOGLE_API_KEY \
    -e ALPHA_VANTAGE_API_KEY \
    -e POLYGON_API_KEY \
    -e PERPLEXITY_API_KEY \
    -e TELEGRAM_BOT_TOKEN \
    -e TELEGRAM_CHAT_ID \
    -e SEC_EDGAR_USER_AGENT \
    -e FRED_API_KEY \
    -e ALPHALENS_TEXTFILE_DIR=/var/lib/node_exporter/textfile \
    -v %h/.alphalens:/app/home/.alphalens \
    -v /var/lib/node_exporter/textfile:/var/lib/node_exporter/textfile \
    --entrypoint /bin/bash \
    alphalens-pipeline:latest \
    /app/deploy/docker/run_thematic_day.sh

# Gap-detection on the news_ingest cache (PR-E, epic #295 Risk A).
# Fires after the pipeline ExecStart succeeds but BEFORE the Django
# rebuild-cache — so a corrupt or missing parquet halts the chain
# rather than silently refreshing Django from incomplete data.
# Telegram alert on the missing-day digest is opt-in via --alert and
# reads TELEGRAM_BOT_TOKEN / TELEGRAM_CHAT_ID from the inherited env.
# Window of 7 days covers a clean operational week + the most-recent
# rebuild window without overshooting catalyst_resolver's 30-day
# lookback (manual --days 30 invocation available for deep audits).
# Runs in the same pipeline image so the alphalens CLI is on PATH; the
# bind mount keeps it inspecting the host cache rather than the
# container's local copy.
#
# **No leading `alphalens` arg.** The pipeline image's ENTRYPOINT is
# `/app/.venv/bin/alphalens` (Dockerfile.pipeline line 84), so the
# tokens after the image name are forwarded as CLI args. Including a
# literal `alphalens` here would make Typer parse it as the first
# subcommand and abort with `No such command 'alphalens'` — observed
# on VPS 2026-05-29 after PR-E rolled out the original wording. Fix:
# args start at `thematic`. The same rule applies to any future
# ExecStartPost using the pipeline image — entrypoint-aware.
ExecStartPost=/usr/bin/docker run --rm \
    --user %U:%G \
    -e HOME=/app/home \
    -e TELEGRAM_BOT_TOKEN \
    -e TELEGRAM_CHAT_ID \
    -v %h/.alphalens:/app/home/.alphalens \
    alphalens-pipeline:latest \
    thematic verify-cache --days 7 --alert

# Sync the parquet output the pipeline just wrote into the Django Postgres
# cache via the maintenance one-shot. ``--profile maintenance`` opt-in
# isolates this from the always-on ``django`` service. ExecStartPost fires
# only on ExecStart success AND the preceding verify-cache exit-0; a
# pipeline failure OR a gap-detect alert leaves the cache untouched so
# the operator can investigate before partial data hits Django.
ExecStartPost=/usr/bin/docker compose \
    -f %h/AlphaLens/deploy/docker/django-prod/docker-compose.yaml \
    --profile maintenance run --rm rebuild-cache

# Prometheus textfile metrics (see alphalens-edgar-detect.service for
# the pattern). Runs unconditionally so a failed pipeline run or
# verify-cache halt also updates the exit code gauge — Alertmanager
# (PR-3) then fires on the non-zero exit.
ExecStopPost=%h/AlphaLens/deploy/systemd/bin/alphalens-emit-job-metrics thematic-build

# Keep stdout/stderr in journald.
StandardOutput=journal
StandardError=journal

# Pipeline runs Polygon news (~few MB JSON), Gemini API calls (network-bound),
# and pandas/parquet I/O. 4G is comfortable headroom on a small VPS; bump if
# the SP500-scale insider gate trips OOM.
MemoryMax=4G
TasksMax=512

# Type=oneshot defaults TimeoutStartSec to infinity (man systemd.service
# §"Type=oneshot"). Without an explicit timeout, a run that wedges on a
# Gemini quota loop, a Polygon retry storm, or a stuck rebuild-cache step
# would block every subsequent timer fire forever — systemd queues new
# fires behind the running unit. 45min = ~3× the typical 15-20min wall
# time; a healthy run never trips this, a wedged one gets SIGTERM (then
# SIGKILL after TimeoutStopSec) so the next 4h slot can fire. Pinned by
# PR-F zen pre-merge review (epic #295 / issue #300).
TimeoutStartSec=45min

# Oneshot doesn't auto-restart on success. On real failures (Polygon 5xx,
# Gemini quota, OOM) systemd surfaces non-zero exit in journalctl + status.
# The timer fires 6× daily (PR-F); a one-slot miss is acceptable.

[Install]
WantedBy=default.target
