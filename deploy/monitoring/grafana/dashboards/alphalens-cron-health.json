{
  "title": "AlphaLens Cron Health",
  "uid": "alphalens-cron-health",
  "tags": ["alphalens", "cron", "observability"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "1m",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "job",
        "label": "Job",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": "label_values(alphalens_job_last_run_timestamp_seconds, job)",
        "multi": true,
        "includeAll": true,
        "current": {
          "selected": false,
          "text": "All",
          "value": "$__all"
        },
        "refresh": 2
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Time since last success",
      "description": "Red when older than 2× the expected cadence. Hover for the exact unit.",
      "gridPos": {"h": 5, "w": 24, "x": 0, "y": 0},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "time() - alphalens_job_last_success_timestamp_seconds{job=~\"$job\"}",
          "legendFormat": "{{ job }}",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 1800},
              {"color": "red", "value": 7200}
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Job duration (last run)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 5},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "alphalens_job_last_duration_seconds{job=~\"$job\"}",
          "legendFormat": "{{ job }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {"lineWidth": 2, "fillOpacity": 10}
        }
      }
    },
    {
      "id": 3,
      "type": "state-timeline",
      "title": "Exit codes (0 = success)",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 5},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "alphalens_job_last_exit_code{job=~\"$job\"}",
          "legendFormat": "{{ job }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "red", "value": 1}
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "type": "row",
      "title": "Domain — EDGAR",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 13},
      "collapsed": false
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "EDGAR events detected vs dispatched",
      "gridPos": {"h": 7, "w": 12, "x": 0, "y": 14},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "alphalens_edgar_events_detected_total",
          "legendFormat": "detected"
        },
        {
          "refId": "B",
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "alphalens_edgar_events_dispatched_total",
          "legendFormat": "dispatched"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {"lineWidth": 2, "fillOpacity": 10}
        }
      }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "EDGAR portfolio size",
      "gridPos": {"h": 7, "w": 12, "x": 12, "y": 14},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "alphalens_edgar_portfolio_size",
          "legendFormat": "{{ class }}",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "green", "value": 1}
            ]
          }
        }
      }
    },
    {
      "id": 7,
      "type": "row",
      "title": "Domain — thematic",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 21},
      "collapsed": false
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Briefs written per day",
      "gridPos": {"h": 7, "w": 12, "x": 0, "y": 22},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "alphalens_thematic_briefs_total",
          "legendFormat": "briefs"
        }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Briefs by model (Pro vs Flash)",
      "gridPos": {"h": 7, "w": 12, "x": 12, "y": 22},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "alphalens_thematic_briefs_by_model",
          "legendFormat": "{{ model }}"
        }
      ]
    },
    {
      "id": 10,
      "type": "row",
      "title": "Domain — Alpha Vantage quota",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 29},
      "collapsed": false
    },
    {
      "id": 11,
      "type": "stat",
      "title": "AV quota remaining today",
      "gridPos": {"h": 7, "w": 12, "x": 0, "y": 30},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "alphalens_av_quota_remaining",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 3},
              {"color": "green", "value": 10}
            ]
          },
          "max": 25,
          "min": 0
        }
      }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "AV tickers by status (last run)",
      "gridPos": {"h": 7, "w": 12, "x": 12, "y": 30},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "alphalens_av_tickers_total",
          "legendFormat": "{{ status }}"
        }
      ]
    }
  ]
}
