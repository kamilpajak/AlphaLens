{
  "name": "web",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "sync:docs": "node scripts/sync-research-docs.mjs",
    "audit:tooltips": "node scripts/audit-tooltips.mjs",
    "predev": "node scripts/sync-research-docs.mjs",
    "prebuild": "node scripts/sync-research-docs.mjs",
    "dev": "vite dev",
    "dev:vps": "node scripts/dev-api-proxy.mjs",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test": "playwright test",
    "test:smoke": "playwright test smoke.test.ts",
    "test:unit": "vitest run",
    "gen:api-types": "openapi-typescript ./openapi/schema.yaml -o ./src/lib/api-types.gen.ts",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@storybook/addon-svelte-csf": "5.1.2",
    "@storybook/sveltekit": "10.4.6",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.69.1",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.2",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^26.1.0",
    "@vitest/coverage-v8": "^3.2.6",
    "js-yaml": "^5.2.1",
    "openapi-typescript": "^7.13.0",
    "storybook": "10.4.6",
    "svelte": "^5.56.4",
    "svelte-check": "^4.7.1",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.2",
    "vite": "^8.1.3",
    "vitest": "^3.2.6"
  },
  "dependencies": {
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource-variable/space-grotesk": "^5.2.10",
    "isomorphic-dompurify": "^3.18.0",
    "lightweight-charts": "^5.2.0",
    "lucide-svelte": "^1.0.1",
    "marked": "^18.0.5",
    "temml": "^0.13.3"
  }
}
