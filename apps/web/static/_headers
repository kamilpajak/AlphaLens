# Cloudflare Pages _headers — explicit cache directives.
#
# Defensive layer against the same CDN edge-cache poisoning fixed in
# _redirects: ensure index.html (and any HTML served as SPA fallback)
# is never cached for more than its revalidation window. Pages already
# sends `cache-control: public, max-age=0, must-revalidate` on the bare
# `/` route, but the SPA fallback inherits the URL's response-class cache
# headers, so a fallback served at a `/_app/*` URL can get the immutable
# asset cache header (~4h). The _redirects 404 prevents that path now;
# this file pins the convention so a future _redirects regression cannot
# silently reintroduce the bug.
/index.html
  Cache-Control: public, max-age=0, must-revalidate

/
  Cache-Control: public, max-age=0, must-revalidate

# The 404 response served by the `_redirects` rule for missing chunk URLs
# under /_app/*. Without this explicit pin, CF Pages can apply the same
# immutable-asset cache policy to the 404 response itself (the URL still
# matches the /_app/immutable/ prefix), poisoning the CDN with a sticky
# 404 for hours. Forcing no-cache means SvelteKit's reload-on-stale-import
# recovery always sees a fresh response on every retry.
/_chunk-404.txt
  Cache-Control: no-cache, must-revalidate, max-age=0
