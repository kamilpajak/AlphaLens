# apps/web local dev env. Copy to `.env` (gitignored) and fill in.
# Only used by `pnpm dev:vps` (the live-VPS data proxy). Plain `pnpm dev`
# needs none of these.

# Base URL of the production briefs API (behind Cloudflare Access).
# `pnpm dev:vps` proxies the SPA's /v1/* calls here, authenticating with a
# Cloudflare Access token (run once: `cloudflared access login --app=$DEV_API_URL`).
DEV_API_URL=https://api.<your-domain>

# Optional: local port for the dev proxy (default 8099).
# DEV_API_PROXY_PORT=8099
