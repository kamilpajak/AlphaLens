{
  "margin_of_safety": "= 1 - P / V_{\\text{intrinsic}}",
  "owner_earnings_yield": "= \\dfrac{\\text{owner earnings}}{EV}",
  "pe": "= \\dfrac{\\text{price}}{\\text{EPS}}",
  "ps": "= \\dfrac{\\text{mkt cap}}{\\text{revenue}}",
  "ev_rev": "= \\dfrac{EV}{\\text{revenue}}",
  "ev_ebitda": "= \\dfrac{EV}{\\text{EBITDA}}",
  "roe": "= \\dfrac{\\text{net income}}{\\text{equity}}",
  "fcf_margin": "= \\dfrac{\\text{FCF}}{\\text{revenue}}",
  "fcff_yield": "= \\dfrac{\\text{FCFF}}{EV}",
  "magic_formula": "= \\text{rank}_{\\text{EY}} + \\text{rank}_{\\text{ROC}}",
  "to_stop": "= \\dfrac{\\text{entry} - \\text{stop}}{\\text{entry}}",
  "risk_at_stop": "= \\text{size} \\times \\dfrac{\\text{entry} - \\text{stop}}{\\text{entry}}",
  "full_ladder_entry": "= \\sum (\\text{tier price} \\times \\text{alloc})",
  "excess_expectancy": "= \\text{mean}(R_{\\text{cand}} - R_{\\text{bench}})",
  "mean_risk": "= \\text{mean}(\\text{size} \\times \\tfrac{\\text{entry} - \\text{stop}}{\\text{entry}})",
  "car": "= \\sum (R_{\\text{actual}} - R_{\\text{expected}})"
}
