                    "meta"
                ],
                "properties": {
                    "data": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/DayMeta"
                        }
                    },
                    "meta": {
                        "type": "object",
                        "required": [
                            "total",
                            "limit",
                            "offset"
                        ],
                        "properties": {
                            "total": {
                                "type": "integer",
                                "example": 123
                            },
                            "limit": {
