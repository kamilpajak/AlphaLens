            "DayBrief": {
                "type": "object",
                "description": "Full payload for one day: meta + every ranked candidate.",
                "properties": {
                    "date": {
                        "type": "string",
                        "format": "date"
                    },
                    "n_candidates": {
                        "type": "integer"
                    },
                    "n_themes": {
                        "type": "integer"
                    },
                    "top_theme": {
                        "type": "string",
                        "nullable": true
                    },
                    "theme_counts": {
                        "type": "object",
                        "additionalProperties": {
                            "type": "integer"
                        }
                    },
                    "candidates": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/Candidate"
                        }
                    }
                },
                "required": [
                    "candidates",
                    "date",
                    "n_candidates",
                    "n_themes",
                    "theme_counts",
                    "top_theme"
                ]
            },
            "DayMeta": {
                "type": "object",
                "description": "Row in ``/v1/days``: per-day metadata only (no candidates).",
                "properties": {
                    "date": {
                        "type": "string",
                        "format": "date"
                    },
                    "n_candidates": {
                        "type": "integer",
                        "maximum": 9223372036854775807,
                        "minimum": -9223372036854775808,
                        "format": "int64"
                    },
                    "n_themes": {
                        "type": "integer",
                        "maximum": 9223372036854775807,
                        "minimum": -9223372036854775808,
                        "format": "int64"
                    },
                    "top_theme": {
                        "type": "string",
                        "nullable": true,
                        "description": "Empty-string DB default → None on the wire (parity with legacy API).",
                        "readOnly": true
                    }
                },
                "required": [
                    "date",
                    "n_candidates",
                    "n_themes",
                    "top_theme"
                ]
            },
            "PaginatedCandidateList": {
                "type": "object",
                "required": [
                    "data",
                    "meta"
                ],
                "properties": {
                    "data": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/Candidate"
                        }
                    },
                    "meta": {
                        "type": "object",
                        "required": [
                            "total",
                            "limit",
                            "offset"
                        ],
                        "properties": {
                            "total": {
                                "type": "integer",
                                "example": 123
                            },
                            "limit": {
                                "type": "integer",
                                "example": 50
                            },
                            "offset": {
                                "type": "integer",
                                "example": 0
                            }
                        }
                    }
                }
            },
