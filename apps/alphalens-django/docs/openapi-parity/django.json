{
    "openapi": "3.0.3",
    "info": {
        "title": "AlphaLens Briefs API",
        "version": "1.0.0",
        "description": "Read/write HTTP access to thematic briefs produced by the AlphaLens daily pipeline."
    },
    "paths": {
        "/v1/candidates/{date}/{ticker}": {
            "get": {
                "operationId": "v1_candidates_retrieve",
                "description": "``/v1/candidates/{date}/{ticker}`` — single candidate fetch.\n\nThe detail PK is supplied as a compound URL segment, not a single field.\nThe router pattern in ``urls.py`` is custom for this reason.",
                "parameters": [
                    {
                        "in": "path",
                        "name": "date",
                        "schema": {
                            "type": "string"
                        },
                        "required": true
                    },
                    {
                        "in": "path",
                        "name": "ticker",
                        "schema": {
                            "type": "string"
                        },
                        "required": true
                    }
                ],
                "tags": [
                    "v1"
                ],
                "security": [
                    {
                        "CloudflareAccessJWT": []
                    },
                    {
                        "cookieAuth": []
                    },
                    {}
                ],
                "responses": {
                    "200": {
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/Candidate"
                                }
                            }
                        },
                        "description": ""
                    }
                }
            }
        },
        "/v1/days": {
            "get": {
                "operationId": "v1_days_list",
                "description": "``/v1/days`` — index + per-day envelope + per-day candidates.",
                "parameters": [
                    {
                        "in": "query",
                        "name": "from",
                        "schema": {
                            "type": "string",
                            "format": "date"
                        },
                        "description": "Inclusive ISO date lower bound."
                    },
                    {
                        "name": "limit",
                        "required": false,
                        "in": "query",
                        "description": "Number of results to return per page.",
                        "schema": {
                            "type": "integer"
                        }
                    },
                    {
                        "name": "offset",
                        "required": false,
                        "in": "query",
                        "description": "The initial index from which to return the results.",
                        "schema": {
                            "type": "integer"
                        }
                    },
                    {
                        "in": "query",
                        "name": "to",
                        "schema": {
                            "type": "string",
                            "format": "date"
                        },
                        "description": "Inclusive ISO date upper bound."
                    }
                ],
                "tags": [
                    "v1"
                ],
                "security": [
                    {
                        "CloudflareAccessJWT": []
                    },
                    {
                        "cookieAuth": []
                    },
                    {}
                ],
                "responses": {
                    "200": {
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/PaginatedDayMetaList"
                                }
                            }
                        },
                        "description": ""
                    }
                }
            }
        },
        "/v1/days/{date}": {
            "get": {
                "operationId": "v1_days_retrieve",
                "description": "``/v1/days`` — index + per-day envelope + per-day candidates.",
                "parameters": [
                    {
                        "in": "path",
                        "name": "date",
                        "schema": {
                            "type": "string",
                            "format": "date"
                        },
                        "description": "ISO 8601 date (YYYY-MM-DD).",
                        "required": true
                    }
                ],
                "tags": [
                    "v1"
                ],
                "security": [
                    {
                        "CloudflareAccessJWT": []
                    },
                    {
                        "cookieAuth": []
                    },
                    {}
                ],
                "responses": {
                    "200": {
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/DayBrief"
                                }
                            }
                        },
                        "description": ""
                    }
                }
            }
        },
        "/v1/days/{date}/candidates": {
            "get": {
                "operationId": "v1_days_candidates_list",
                "description": "``/v1/days`` — index + per-day envelope + per-day candidates.",
                "parameters": [
                    {
                        "in": "path",
                        "name": "date",
                        "schema": {
                            "type": "string",
                            "format": "date"
                        },
                        "description": "ISO 8601 date (YYYY-MM-DD).",
                        "required": true
                    },
                    {
                        "name": "limit",
                        "required": false,
                        "in": "query",
                        "description": "Number of results to return per page.",
                        "schema": {
                            "type": "integer"
                        }
                    },
                    {
                        "in": "query",
                        "name": "min_score",
                        "schema": {
                            "type": "integer"
                        },
                        "description": "Layer-4 score floor."
                    },
                    {
                        "name": "offset",
                        "required": false,
                        "in": "query",
                        "description": "The initial index from which to return the results.",
                        "schema": {
                            "type": "integer"
                        }
                    },
                    {
                        "in": "query",
                        "name": "theme",
                        "schema": {
                            "type": "string"
                        },
                        "description": "Exact theme match."
                    }
                ],
                "tags": [
                    "v1"
                ],
                "security": [
                    {
                        "CloudflareAccessJWT": []
                    },
                    {
                        "cookieAuth": []
                    },
                    {}
                ],
                "responses": {
                    "200": {
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/PaginatedCandidateList"
                                }
                            }
                        },
                        "description": ""
                    }
                }
            }
        },
        "/v1/stats": {
            "get": {
                "operationId": "v1_stats_retrieve",
                "description": "``/v1/stats`` — top-line counters + N most-frequent themes.",
                "parameters": [
                    {
                        "in": "query",
                        "name": "top_n",
                        "schema": {
                            "type": "integer"
                        },
                        "description": "Top themes to include (1-50)."
                    }
                ],
                "tags": [
                    "v1"
                ],
                "security": [
                    {
                        "CloudflareAccessJWT": []
                    },
                    {
                        "cookieAuth": []
                    },
                    {}
                ],
                "responses": {
                    "200": {
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/Stats"
                                }
                            }
                        },
                        "description": ""
                    }
                }
            }
        },
        "/v1/themes": {
            "get": {
                "operationId": "v1_themes_list",
                "description": "``/v1/themes`` — distinct-theme aggregation + per-theme candidates.",
                "parameters": [
                    {
                        "in": "query",
                        "name": "from",
                        "schema": {
                            "type": "string",
                            "format": "date"
                        },
                        "description": "Inclusive ISO date lower bound."
                    },
                    {
                        "name": "limit",
                        "required": false,
