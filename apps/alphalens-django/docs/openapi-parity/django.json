                            "type": "string",
                            "format": "date"
                        },
                        "description": "Inclusive ISO date upper bound."
                    }
                ],
                "tags": [
                    "v1"
                ],
                "security": [
                    {
                        "CloudflareAccessJWT": []
                    },
                    {
                        "cookieAuth": []
                    },
                    {}
                ],
                "responses": {
                    "200": {
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/PaginatedThemeSummaryList"
                                }
                            }
                        },
                        "description": ""
                    }
                }
            }
        },
        "/v1/themes/{theme}/candidates": {
            "get": {
                "operationId": "v1_themes_candidates_list",
                "description": "``/v1/themes`` — distinct-theme aggregation + per-theme candidates.",
                "parameters": [
                    {
                        "in": "query",
                        "name": "from",
                        "schema": {
                            "type": "string",
                            "format": "date"
                        },
                        "description": "Inclusive ISO date lower bound."
                    },
                    {
                        "name": "limit",
                        "required": false,
                        "in": "query",
                        "description": "Number of results to return per page.",
                        "schema": {
                            "type": "integer"
                        }
                    },
                    {
                        "name": "offset",
                        "required": false,
                        "in": "query",
                        "description": "The initial index from which to return the results.",
                        "schema": {
                            "type": "integer"
                        }
                    },
                    {
                        "in": "path",
                        "name": "theme",
                        "schema": {
                            "type": "string"
                        },
                        "description": "Exact theme name.",
                        "required": true
                    },
                    {
                        "in": "query",
                        "name": "to",
                        "schema": {
                            "type": "string",
                            "format": "date"
                        },
                        "description": "Inclusive ISO date upper bound."
                    }
                ],
                "tags": [
                    "v1"
                ],
                "security": [
                    {
                        "CloudflareAccessJWT": []
                    },
                    {
                        "cookieAuth": []
                    },
                    {}
                ],
                "responses": {
                    "200": {
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/PaginatedCandidateList"
                                }
                            }
                        },
                        "description": ""
                    }
                }
            }
        },
        "/v1/tickers/{ticker}/history": {
            "get": {
                "operationId": "v1_tickers_history_list",
                "description": "``/v1/tickers/{ticker}/history`` — every brief appearance for one ticker.",
                "parameters": [
                    {
                        "in": "query",
                        "name": "from",
                        "schema": {
                            "type": "string",
                            "format": "date"
                        },
                        "description": "Inclusive ISO date lower bound."
                    },
                    {
                        "name": "limit",
                        "required": false,
                        "in": "query",
                        "description": "Number of results to return per page.",
                        "schema": {
                            "type": "integer"
                        }
                    },
                    {
                        "name": "offset",
                        "required": false,
                        "in": "query",
                        "description": "The initial index from which to return the results.",
                        "schema": {
                            "type": "integer"
                        }
                    },
                    {
                        "in": "path",
                        "name": "ticker",
                        "schema": {
                            "type": "string"
                        },
                        "description": "Upper-case ticker symbol.",
                        "required": true
                    },
                    {
                        "in": "query",
                        "name": "to",
                        "schema": {
                            "type": "string",
                            "format": "date"
                        },
                        "description": "Inclusive ISO date upper bound."
                    }
                ],
                "tags": [
                    "v1"
                ],
                "security": [
                    {
                        "CloudflareAccessJWT": []
                    },
                    {
                        "cookieAuth": []
                    },
                    {}
