                "responses": {
                    "200": {
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/PaginatedCandidateList"
                                }
                            }
                        },
                        "description": ""
                    }
                }
            }
        }
    },
