                    },
                    "meta": {
                        "type": "object",
                        "required": [
                            "total",
                            "limit",
                            "offset"
                        ],
                        "properties": {
                            "total": {
                                "type": "integer",
                                "example": 123
                            },
                            "limit": {
                                "type": "integer",
                                "example": 50
                            },
                            "offset": {
                                "type": "integer",
                                "example": 0
                            }
                        }
                    }
                }
            },
            "Stats": {
                "type": "object",
                "description": "Top-line counters and most-frequent themes for ``/v1/stats``.",
                "properties": {
                    "n_days": {
                        "type": "integer"
                    },
                    "n_candidates": {
                        "type": "integer"
                    },
                    "n_themes": {
                        "type": "integer"
                    },
                    "earliest_date": {
                        "type": "string",
                        "format": "date",
                        "nullable": true
                    },
                    "latest_date": {
                        "type": "string",
                        "format": "date",
                        "nullable": true
                    },
                    "last_rebuild_at": {
                        "type": "string",
                        "format": "date-time",
                        "nullable": true
                    },
                    "top_themes": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/TopTheme"
                        }
                    }
                },
                "required": [
                    "earliest_date",
                    "last_rebuild_at",
                    "latest_date",
                    "n_candidates",
                    "n_days",
                    "n_themes",
                    "top_themes"
                ]
            },
            "ThemeSummary": {
                "type": "object",
                "description": "Row in ``/v1/themes``: distinct theme + appearance counts.",
                "properties": {
                    "theme": {
                        "type": "string"
                    },
                    "n_candidates": {
                        "type": "integer"
                    },
                    "n_days": {
                        "type": "integer"
                    },
                    "first_seen": {
                        "type": "string",
                        "format": "date"
                    },
                    "last_seen": {
                        "type": "string",
                        "format": "date"
                    }
                },
                "required": [
                    "first_seen",
                    "last_seen",
                    "n_candidates",
                    "n_days",
                    "theme"
                ]
            },
            "TopTheme": {
                "type": "object",
                "properties": {
                    "theme": {
                        "type": "string"
                    },
                    "n_days": {
                        "type": "integer"
                    },
                    "n_candidates": {
                        "type": "integer"
                    }
                },
                "required": [
                    "n_candidates",
                    "n_days",
                    "theme"
                ]
            }
        },
        "securitySchemes": {
            "CloudflareAccessJWT": {
                "type": "apiKey",
                "in": "header",
                "name": "Cf-Access-Jwt-Assertion",
                "description": "Cloudflare Access service token / SSO JWT, injected by the Cloudflare edge after the user passes the configured identity provider (Google SSO). Verified server-side against the team's JWKS."
            },
            "cookieAuth": {
                "type": "apiKey",
                "in": "cookie",
                "name": "sessionid"
            }
        }
    }
}
